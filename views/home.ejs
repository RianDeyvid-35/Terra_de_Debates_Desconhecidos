<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feed | TDD</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand" href="/feed">
                <i class="bi bi-play-fill"></i> T.D.D
            </a>

            <div class="d-flex align-items-center">
                <a href="/posts/new" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block" target="_blank">
                    <i class="bi bi-plus-square me-1"></i>Novo Debate
                </a>
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="<%= user.profilePicture ? '/uploads/profiles/' + user.profilePicture : 'default-profile.png' %>" 
                            alt="mdo" width="32" height="32" class="bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i>Meu
                                Perfil</a></li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i
                                    class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">
            <!-- Sidebar (Desktop) -->
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4">
                <nav class="nav flex-column">
                    <a class="nav-link active" href="/feed"><i class="bi bi-house-door-fill me-2"></i> Para Você</a>
                    <hr>
                </nav>
            </aside>

            <!-- Main Content -->
            <main class="col-12 col-md-9 col-lg-10 py-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">Discussões em alta</h4>
                </div>

     <div class="row g-4">
    <% if (posts && posts.length > 0) { %>
        <% posts.forEach(post => { %>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="video-card">
                    <a href="/posts/<%= post.id %>">
                        <div class="thumbnail-placeholder"></div>
                    </a>
                    <div class="p-3">
                        <h6 class="text-truncate"><%= post.title %></h6>
                        <small class="text-muted">
                            @<%= post.User ? post.User.username : 'UsuarioDesconhecido' %>
                        </small>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <p>Nenhum debate criado ainda.</p>
    <% } %>
</div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>