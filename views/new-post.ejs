<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Nova Postagem | TDD</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand" href="/feed">
                <i class="bi bi-play-fill"></i> T.D.D
            </a>


            <div class="d-flex align-items-center">
                <a href="/posts/new" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block">
                    <i class="bi bi-plus-square me-1"></i>Novo Debate
                </a>
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="<%= user.profilePicture ? '/uploads/profiles/' + user.profilePicture : '/images/default-profile.png' %>"
                            alt="mdo" width="32" height="32" class="bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i>Meu
                                Perfil</a></li>
                        <li><a class="dropdown-item py-2" href="/feed"><i class="bi bi-camera-video me-2"></i> Feed</a></li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i
                                    class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h4 class="mb-0">Criar Nova Postagem</h4>
                    </div>

                    <div class="card-body p-4">
                        <form action="/posts" method="POST">

                            <div class="mb-3">
                                <label for="title" class="form-label">
                                    Título da Discussão
                                </label>

                                <input
                                    type="text"
                                    class="form-control"
                                    id="title"
                                    name="title"
                                    placeholder="Ex: Dúvida sobre Testes de Integração"
                                    required
                                >
                            </div>

                            <div class="mb-3">
                                <label for="content" class="form-label">
                                    Conteúdo da Postagem
                                </label>

                                <textarea
                                    class="form-control"
                                    id="content"
                                    name="content"
                                    rows="8"
                                    placeholder="Descreva sua dúvida, ideia ou discussão..."
                                    required
                                ></textarea>

                                <div class="form-text">
                                    Explique sua dúvida ou compartilhe sua discussão com a turma.
                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-4">
                                <button
                                    type="submit"
                                    class="btn btn-primary btn-lg"
                                >
                                    Publicar
                                </button>

                                <a
                                    href="/posts"
                                    class="btn btn-outline-secondary btn-lg"
                                >
                                    Cancelar
                                </a>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>