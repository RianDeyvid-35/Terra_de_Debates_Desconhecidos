<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
 <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- CSS do projeto -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm">
    <div class="container-fluid px-lg-5">
        <a class="navbar-brand" href="/feed">
            <i class="bi bi-play-fill"></i>
            T.D.D
        </a>
        <div class="d-flex align-items-center">
            <a href="/posts/new" class="btn btn-outline-dark border-0 me-3">
                <i class="bi bi-plus-square"></i>
                Nova Postagem
            </a>
            <div class="dropdown">
                <a
                    href="#"
                    class="d-block link-dark text-decoration-none dropdown-toggle"
                    data-bs-toggle="dropdown">
                    <img
                        src="<%= user && user.profilePicture
                            ? '/uploads/profiles/' + user.profilePicture
                            : 'default-profile.png' %>"
                        width="38"
                        height="38"
                        class="rounded-circle border">
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <a
                            class="dropdown-item"
                            href="/profile/edit">
                            Meu Perfil
                        </a>
                    </li>
                    <li>
                        <a
                            class="dropdown-item"
                            href="/feed">
                            Feed
                        </a>
                    </li>
                    <li>
                        <hr>
                    </li>
                    <li>
                        <a
                            class="dropdown-item text-danger"
                            href="/logout">
                            Sair
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="fw-bold mb-3">
                        <%= post.title %>
                    </h2>
                    <div class="d-flex align-items-center mb-3">
                        <!-- Foto do usuário -->
                        <img
                            src="<%= post.User && post.User.profilePicture
                                ? '/uploads/profiles/' + post.User.profilePicture
                                : 'default-profile.png' %>"
                            class="rounded-circle me-3"
                            width="50"
                            height="50">
                        <!-- Nome e username -->
                        <div>
                            <strong>
                                <%= post.User
                                    ? post.User.fullName
                                    : "Usuário removido" %>
                            </strong>
                            <br>
                            <small class="text-muted">
                                @<%= post.User
                                    ? post.User.username
                                    : "desconhecido" %>
                            </small>
                        </div>
                        <div class="ms-auto">
                            <small class="text-muted">
                                <%= new Date(post.createdAt).toLocaleDateString("pt-BR") %>
                            </small>
                        </div>
                    </div>
                    <hr>
                    <p
                        class="fs-5"
                        style="white-space:pre-line;">
                        <%= post.content %>
                    </p>
                </div>
            </div>
            <% if(user && user.id === post.userId){ %>
                <div class="mb-4">
                    <form
                        action="/posts/<%= post.id %>/delete"
                        method="POST">
                        <button
                            class="btn btn-danger"
                            onclick="return confirm('Deseja excluir esta postagem?')">
                            <i class="bi bi-trash"></i>
                            Excluir postagem
                        </button>
                    </form>
                </div>
            <% } %>
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="mb-4">
                        <i class="bi bi-chat-left-text"></i>
                        Comentários
                        (<span id="commentsCountDisplay">
                            <%= post.commentsCount || 0 %>
                        </span>)
                    </h4>
                    <% if(user){ %>
                        <form id="commentForm">
                            <div class="mb-3">
                                <textarea
                                    id="commentContent"
                                    class="form-control"
                                    rows="4"
                                    placeholder="Escreva um comentário..."
                                    required>
                                </textarea>
                            </div>
                            <button
                                type="submit"
                                class="btn btn-primary">
                                <i class="bi bi-send"></i>
                                Comentar
                            </button>
                        </form>
                        <hr>
                    <% }else{ %>
                        <div class="alert alert-warning">
                            Faça login para comentar.
                        </div>
                    <% } %>
                    <div id="commentsList">
                    </div>
                </div>
            </div>
                    </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>

document.addEventListener("DOMContentLoaded", () => {
    const postId = "<%= post.id %>";

    const commentForm = document.getElementById("commentForm");
    const commentContent = document.getElementById("commentContent");
    const commentsList = document.getElementById("commentsList");
    const commentsCountDisplay = document.getElementById("commentsCountDisplay");
    async function loadComments(){

        try{
            const response = await fetch(`/posts/${postId}/comments`);
            const data = await response.json();
            commentsList.innerHTML = "";

            if(data.comments.length === 0){

                commentsList.innerHTML = `
                    <div class="alert alert-light border">
                        Ainda não existe nenhum comentário.
                    </div>
                `;
                commentsCountDisplay.textContent = 0;
                return;
            }
            commentsCountDisplay.textContent = data.comments.length;


            data.comments.forEach(comment =>{
                commentsList.insertAdjacentHTML("beforeend",`
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <img
                                    src="${
                                        comment.User && comment.User.profilePicture
                                        ? '/uploads/profiles/' + comment.User.profilePicture
                                        : '/images/default-profile.png'
                                    }"
                                    class="rounded-circle me-3"
                                    width="45"
                                    height="45">
                                <div>
                                    <strong>
                                        ${
                                            comment.User
                                            ? comment.User.fullName
                                            : "Usuário removido"
                                        }
                                    </strong>
                                    <br>
                                    <small class="text-muted">
                                        @${
                                            comment.User
                                            ? comment.User.username
                                            : "desconhecido"
                                        }
                                    </small>
                                </div>
                                <div class="ms-auto">
                                    <small class="text-muted">

                                        ${new Date(comment.createdAt).toLocaleString("pt-BR")}

                                    </small>
                                </div>
                            </div>
                            <hr>
                            <p class="mb-0">
                                ${comment.content}
                            </p>
                        </div>
                    </div>
                `);
            });
        }

        catch(error){
            console.error(error);
            commentsList.innerHTML = `
                <div class="alert alert-danger">
                    Erro ao carregar comentários.
                </div>
            `;
        }
    }
    loadComments();

    if(commentForm){
        commentForm.addEventListener("submit", async (e)=>{
            e.preventDefault();
            const content = commentContent.value.trim();
            if(content === ""){
                alert("Digite um comentário.");
                return;
            }
            try{
                const response = await fetch(`/posts/${postId}/comments`,{
                    method:"POST",
                    headers:{
                        "Content-Type":"application/json"
                    },

                    body:JSON.stringify({
                        content
                    })

                });

                const data = await response.json();
                if(response.ok){
                    commentContent.value = "";
                    loadComments();
                }else{
                    alert(data.message);
                }

            }

            catch(error){
                console.error(error);
                alert("Erro ao enviar comentário.");
            }
        });
    }

});

</script>

</body>
</html>